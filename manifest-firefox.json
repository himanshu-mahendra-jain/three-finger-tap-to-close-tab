{
    "manifest_version": 3,
    "name": "Three Finger Tap to Close Tab",
    "version": "1.0.1",
    "description": "Close the current tab with a three-finger tap or middle click outside links and editable fields.",
    "browser_specific_settings": {
        "gecko": {
            "id": "three-finger-tap-to-close-tab@himanshu-mahendra-jain",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "icons": {
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "Three Finger Tap to Close Tab",
        "default_icon": {
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "scripts": [
            "src/background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content.js"
            ],
            "all_frames": false,
            "run_at": "document_start"
        }
    ]
}